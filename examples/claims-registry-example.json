{
  "registry_version": "1.0",
  "claims": {
    "given_name": {
      "type": "string",
      "description": "Person's given name(s) as appears on official documents",
      "aliases": ["first_name", "forename", "given_names"],
      "max_length": 100,
      "domains": ["IDENTITY", "AUTHORIZATION", "MEMBERSHIP"],
      "categories": ["PERSON_IDENTIFICATION", "DRIVING_LICENSE"],
      "validation": {
        "pattern": "^[\\p{L}\\s\\-\\'\\.']+$",
        "min_length": 1
      }
    },
    "family_name": {
      "type": "string",
      "description": "Person's family name as appears on official documents",
      "aliases": ["last_name", "surname", "family_names"],
      "max_length": 100,
      "domains": ["IDENTITY", "AUTHORIZATION", "MEMBERSHIP"],
      "categories": ["PERSON_IDENTIFICATION", "DRIVING_LICENSE"],
      "validation": {
        "pattern": "^[\\p{L}\\s\\-\\'\\.']+$",
        "min_length": 1
      }
    },
    "birth_date": {
      "type": "date",
      "description": "Date of birth in ISO 8601 format",
      "format": "YYYY-MM-DD",
      "domains": ["IDENTITY", "AUTHORIZATION"],
      "categories": ["PERSON_IDENTIFICATION", "DRIVING_LICENSE"],
      "validation": {
        "min_date": "1900-01-01",
        "max_date": "current_date"
      }
    },
    "birth_place": {
      "type": "string",
      "description": "Place of birth as registered in official records",
      "aliases": ["place_of_birth"],
      "max_length": 100,
      "domains": ["IDENTITY", "AUTHORIZATION"],
      "categories": ["GOVERNMENT_ID", "DRIVING_LICENSE"]
    },
    "tax_code": {
      "type": "string",
      "description": "Italian fiscal identification code (Codice Fiscale)",
      "domains": ["IDENTITY"],
      "categories": ["PERSON_IDENTIFICATION"],
      "validation": {
        "pattern": "^[A-Z]{6}[0-9]{2}[A-Z][0-9]{2}[A-Z][0-9]{3}[A-Z]$",
        "length": 16
      }
    },
    "personal_administrative_number": {
      "type": "string",
      "description": "ANPR unique person identifier",
      "domains": ["IDENTITY"],
      "categories": ["PERSON_IDENTIFICATION"],
      "validation": {
        "pattern": "^[A-Z0-9]+$"
      }
    },
    "document_number": {
      "type": "string",
      "description": "Document serial number or identifier",
      "domains": ["IDENTITY", "AUTHORIZATION"],
      "categories": ["PERSON_IDENTIFICATION", "DRIVING_LICENSE"],
      "validation": {
        "pattern": "^[A-Z0-9]+$",
        "max_length": 20
      }
    },
    "issue_date": {
      "type": "date",
      "description": "Document issue date",
      "format": "YYYY-MM-DD",
      "domains": ["AUTHORIZATION"],
      "categories": ["DRIVING_LICENSE"],
      "validation": {
        "max_date": "current_date"
      }
    },
    "expiry_date": {
      "type": "date",
      "description": "Document expiry date",
      "format": "YYYY-MM-DD",
      "domains": ["AUTHORIZATION"],
      "categories": ["DRIVING_LICENSE"],
      "validation": {
        "min_date": "current_date"
      }
    },
    "driving_privileges": {
      "type": "array",
      "description": "Array of authorized vehicle categories with details",
      "domains": ["AUTHORIZATION"],
      "categories": ["DRIVING_LICENSE"],
      "items": {
        "type": "object",
        "properties": {
          "vehicle_category_code": {
            "type": "string",
            "enum": ["AM", "A1", "A2", "A", "B", "BE", "C", "CE", "D", "DE"]
          },
          "issue_date": {"type": "date", "format": "YYYY-MM-DD"},
          "expiry_date": {"type": "date", "format": "YYYY-MM-DD"},
          "restrictions": {"type": "string", "description": "Category-specific restrictions"}
        }
      }
    },
    "portrait": {
      "type": "string",
      "format": "binary",
      "description": "Person's photograph as binary string (JPEG or JPEG2000)",
      "encoding": "base64",
      "content_type": ["image/jpeg", "image/jp2"],
      "domains": ["AUTHORIZATION", "IDENTITY"],
      "categories": ["DRIVING_LICENSE", "PERSON_IDENTIFICATION"],
      "validation": {
        "max_size_bytes": 50000,
        "min_width": 100,
        "min_height": 100
      }
    },
    "issuing_authority": {
      "type": "string",
      "description": "Authority that issued the document",
      "max_length": 100,
      "domains": ["AUTHORIZATION"],
      "categories": ["DRIVING_LICENSE"]
    },
    "issuing_country": {
      "type": "string",
      "description": "Country code that issued the document",
      "domains": ["AUTHORIZATION"],
      "categories": ["DRIVING_LICENSE"],
      "validation": {
        "pattern": "^[A-Z]{2}$",
        "length": 2
      }
    }
  }
}